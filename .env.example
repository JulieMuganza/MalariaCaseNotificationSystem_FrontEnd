# Production (Vercel): set both to your Render API origin, no trailing slash
VITE_API_URL=https://your-backend-name.onrender.com
VITE_BACKEND_ORIGIN=https://your-backend-name.onrender.com

# Local dev: optional; Vite proxy can serve /api — use backend URL if you skip the proxy
# VITE_API_URL=
# VITE_BACKEND_ORIGIN=http://localhost:3000
